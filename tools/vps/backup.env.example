# REQ-0065 — Config del backup de SGInmo (PLANTILLA).
# Copiar a un archivo PROTEGIDO fuera del repo, p.ej.:
#   /home/edm/sginmo/backup.env   (chmod 600, dueno edm)
# El script lo carga desde $SGINMO_BACKUP_ENV (default esa ruta).
# NUNCA versionar el archivo real con la clave.

# Conexion PostgreSQL (la app corre con la BD en localhost)
PGHOST=localhost
PGPORT=5432
PGDATABASE=sginmo
PGUSER=sginmo
PGPASSWORD=CAMBIAR_POR_LA_CLAVE_REAL

# Destino y repositorio documental
SGINMO_BACKUP_ROOT=/home/edm/backups
SGINMO_ARCHIVOS_DIR=/home/edm/sginmo/archivos

# Retencion (cantidad a conservar por clase)
SGINMO_KEEP_DAILY=7
SGINMO_KEEP_WEEKLY=4
SGINMO_KEEP_MONTHLY=6
